# Caddy: автоматический HTTPS (Let's Encrypt) + реверс-прокси.
# DNS всех доменов ниже должен указывать (A-записи) на этот сервер.
# Caddy сам получит и продлит TLS-сертификаты.

# Кабинет клиента (апекс-домен) — тот же SPA-бандл, что и админка;
# роль `client` после входа уводит на /cabinet.
vittoria-home.ru {
    reverse_proxy admin:80
}

# www → без www
www.vittoria-home.ru {
    redir https://vittoria-home.ru{uri} permanent
}

# Панель сотрудников (админ/партнёр)
admin.vittoria-home.ru {
    reverse_proxy admin:80
}

# Сервер (API)
api.vittoria-home.ru {
    reverse_proxy api:3000
}
